{
  "expo": {
    "name": "ZEV",
    "slug": "zev",
    "scheme": "zev",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0f1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zev.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f1117"
      },
      "package": "com.zev.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
